# Auto Matome — daily pipeline runner
# Python 3.12 + Node.js 22 + Playwright + Wrangler
FROM python:3.12-bookworm

# ── System deps ──────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl git ca-certificates gnupg \
    # Playwright/Chromium system deps
    libglib2.0-0 libnss3 libnspr4 libdbus-1-3 libatk1.0-0 \
    libatk-bridge2.0-0 libcups2 libdrm2 libxkbcommon0 libxcomposite1 \
    libxdamage1 libxfixes3 libxrandr2 libgbm1 libasound2 \
    libx11-6 libxext6 libxfixes3 libxi6 libxrender1 libxtst6 \
    fonts-liberation fonts-noto-color-emoji \
    && rm -rf /var/lib/apt/lists/*

# ── Node.js 22 via NodeSource ─────────────────────────────────
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# ── Global npm packages ───────────────────────────────────────
RUN npm install -g \
    wrangler \
    && npm cache clean --force

# ── Copy source ───────────────────────────────────────────────
# Build with: podman build -f container/Containerfile -t k12-auto-matome:local .
# from the auto-matome repo root
COPY app/ /app/app/
COPY common/ /app/common/
COPY container/ /app/container/

WORKDIR /app/app

# ── Install Python dependencies ───────────────────────────────
RUN python -m venv .venv \
    && .venv/bin/pip install --no-cache-dir \
        -e /app/common \
        -e . \
        notebooklm-py \
        playwright \
        python-dotenv

# ── Install Playwright Chromium ───────────────────────────────
RUN .venv/bin/playwright install chromium --with-deps

# ── Install Node.js deps for Astro site ──────────────────────
RUN if [ -f package.json ]; then npm install; fi
RUN if [ -d site ]; then npm --prefix site install; fi

# ── Prepare directories ───────────────────────────────────────
RUN mkdir -p /data /auth

# ── Entrypoint ────────────────────────────────────────────────
COPY container/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

VOLUME ["/data", "/auth"]

ENTRYPOINT ["/entrypoint.sh"]
