---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const entries = (await getCollection("daily")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<BaseLayout title="オートまとめ" description="HN・IndieWeb・Redditの話題を毎日自動収集してまとめます。">
  <section class="hero">
    <div class="hero-inner">
      <img src="/mascot.png" alt="マスコット" class="hero-mascot" />
      <div>
        <p class="eyebrow">Daily Auto Curation</p>
        <h1>今日のまとめ</h1>
        <p class="lede">HN・IndieWeb・Reddit の話題を毎日自動収集してお届けします。</p>
      </div>
    </div>
  </section>

  <section class="card-grid">
    {entries.map((entry) => (
      <a class="archive-card" href={`/daily/${entry.slug}/`}>
        <p class="card-date">{entry.data.date.toISOString().slice(0, 10)}</p>
        <div class="archive-card-body">
          <h2>{entry.data.title}</h2>
          <p>{entry.data.description}</p>
        </div>
        <span class="card-meta">{entry.data.source}</span>
      </a>
    ))}
  </section>
</BaseLayout>
