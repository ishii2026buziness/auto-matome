---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Auto Matome daily curation built from Hacker News and IndieWeb feeds.",
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a href="/" class="brand">
          <img src="/logo.png" alt="オートまとめ" class="site-logo" />
        </a>
        <p class="tagline">HN + IndieWeb daily curation</p>
      </header>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
